root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{bash,sh}]
indent_size = 4
indent_style = space
# shfmt
space_redirects = true
switch_case_indent = true

[*.{yaml,yml}]
indent_size = 2
indent_style = space

[Justfile]
indent_size = 4
indent_style = space
